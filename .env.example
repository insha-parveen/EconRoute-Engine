# .env.example
cat > .env.example << 'EOF'
GROQ_API_KEY=gsk_your_key_here
OLLAMA_BASE_URL=http://localhost:11434
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://econroute:econroute@postgres:5432/econroute
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_SECONDS=3600
SIMPLE_MODEL=groq/llama-3.1-8b-instant
MEDIUM_MODEL=groq/llama-3.3-70b-versatile
COMPLEX_MODEL=groq/deepseek-r1-distill-llama-70b
FALLBACK_TO_OLLAMA=true
FALLBACK_TIMEOUT_SECONDS=8
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/requests
LOG_LEVEL=INFO
EOF

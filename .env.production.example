# ─── EconRoute Production Environment Variables ──────────────────────────────
# Set these in Railway Dashboard (Variables tab) and Vercel Dashboard (Env vars)

# Required: Groq API key for free inference
# Get one at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Postgres — use Neon (free serverless Postgres)
# 1. Go to https://neon.tech → sign up with GitHub
# 2. Create a project → region: Singapore
# 3. Copy the connection string below (use asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/econroute?sslmode=require

# Redis — use Upstash (free serverless Redis)
# 1. Go to https://upstash.com → sign up with GitHub
# 2. Create a Redis database → region: Singapore
# 3. Copy the REST URL below
REDIS_URL=redis://default:pass@xxx.upstash.io:6379

# Dashboard (Streamlit) — local dev only, uses sync psycopg2
DASHBOARD_DATABASE_URL=postgresql+psycopg2://econroute:econroute@localhost:5432/econroute

# Cache tuning
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_SECONDS=3600

# Model overrides (optional — defaults in providers/model_config.py)
SIMPLE_MODEL=groq/openai/gpt-oss-20b
MEDIUM_MODEL=groq/llama-3.3-70b-versatile
COMPLEX_MODEL=groq/openai/gpt-oss-120b

# Ollama fallback — disabled in production (no local GPU)
FALLBACK_TO_OLLAMA=false

# Logging
LOG_LEVEL=INFO

# Frontend — set in Vercel dashboard (NOT here, used by browser)
# NEXT_PUBLIC_API_URL=https://econroute.up.railway.app
# NEXT_PUBLIC_WS_URL=wss://econroute.up.railway.app/ws/requests

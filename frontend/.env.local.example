# Browser-exposed config (NEXT_PUBLIC_* is inlined into the client bundle — never secrets).
# Copy to .env.local for host `npm run dev`. The docker-compose frontend service sets these
# directly, so .env.local is only needed when running outside compose.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/requests

{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "env": {
    "NEXT_PUBLIC_API_URL": "https://econroute.up.railway.app",
    "NEXT_PUBLIC_WS_URL": "wss://econroute.up.railway.app/ws/requests"
  }
}
